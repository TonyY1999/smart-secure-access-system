    {
        "id": "ui_table",
        "type": "ui_template",
        "z": "mqtt_full_ui_tab",
        "group": "ui_group_fixed",
        "name": "Fingerprint Table",
        "order": 0,
        "width": "12",
        "height": "10",
        "format": "<script>\n  (function(scope) {\n    scope.$watch('msg.payload.fingerprints', function(newVal) {\n        if (newVal) {\n            scope.fingerprints = newVal;\n\n            if (!newVal.find(fp => fp.id === scope.selected)) {\n                scope.selected = null;\n            }\n        }\n    });\n  })(scope);\n</script>\n\n<table border='1' style='width:100%; text-align:center;'>\n  <thead>\n    <tr>\n      <th>Check</th>\n      <th>ID</th>\n      <th>Type</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr ng-repeat=\"fp in fingerprints\">\n      <td><input type=\"radio\" ng-model=\"$parent.selected\" ng-value=\"fp.id\" name=\"select\"></td>\n      <td>{{fp.id}}</td>\n      <td>{{fp.type}}</td>\n    </tr>\n  </tbody>\n</table>\n<br>\n<button ng-click=\"send({payload: selected})\">Delete Selected Fingerprint</button>",
        "storeOutMessages": false,
        "fwdInMessages": false,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 630,
        "y": 80,
        "wires": [
            [
                "delete_logic"
            ]
        ]
    },
    {
        "id": "delete_logic",
        "type": "function",
        "z": "mqtt_full_ui_tab",
        "name": "Delete Fingerprint",
        "func": "let deleteId = msg.payload;\nlet list = flow.get(\"fingerprints\") || [];\n\n// delete\nlist = list.filter(fp => fp.id !== deleteId);\nflow.set(\"fingerprints\", list);\n\n// update UI\nlet uiUpdate = { payload: { fingerprints: list } };\n\n// send mqtt message\nlet mqttMsg = {\n    topic: \"a10g/fingerprint/cmd\", \n    payload: {\n        command: \"delete\",\n        finger_id: deleteId\n    }\n};\n\nreturn [uiUpdate, mqttMsg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 810,
        "y": 180,
        "wires": [
            [
                "ui_table"
            ],
            [
                "aa36923d1b20c4f2",
                "1330051adfb7e366"
            ]
        ]
    },
