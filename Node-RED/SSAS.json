    {
        "id": "ui_buttons",
        "type": "ui_template",
        "z": "mqtt_full_ui_tab",
        "group": "b7af0d8fa35bf95e",
        "name": "Select Window",
        "order": 2,
        "width": "1",
        "height": "1",
        "format": "<div ng-show=\"msg.payload.show\" style=\"\n  position: fixed;\n  top: 30%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: white;\n  border: 2px solid #2196F3;\n  box-shadow: 0 4px 8px rgba(0,0,0,0.2);\n  padding: 20px;\n  z-index: 9999;\n  border-radius: 10px;\n  text-align: center;\n  width: 300px;\n\">\n  <p style=\"font-size: 16px; margin-bottom: 20px;\">{{msg.payload.message}}</p>\n  <button ng-click=\"send({payload: { result: 'allow', finger_id: msg.payload.finger_id, action: msg.payload.action }})\"\n          style=\"margin: 0 10px; padding: 8px 16px; background-color: #4CAF50; color: white; border: none; border-radius: 5px;\">\n    ✅ Allow\n  </button>\n  <button ng-click=\"send({payload: { result: 'deny', finger_id: msg.payload.finger_id, action: msg.payload.action }})\"\n          style=\"margin: 0 10px; padding: 8px 16px; background-color: #F44336; color: white; border: none; border-radius: 5px;\">\n    ❌ Deny\n  </button>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
