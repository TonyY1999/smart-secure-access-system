    {
        "id": "b7d5af3a11a8f5fa",
        "type": "function",
        "z": "mqtt_full_ui_tab",
        "name": "Deal with Selection",
        "func": "let res = msg.payload;\nlet list = flow.get(\"fingerprints\") || [];\n\nif (res.result === \"allow\") {\n    if (res.action === \"add\") {\n        let exists = list.find(fp => fp.id === res.finger_id);\n        if (!exists) {\n            let type = res.finger_id === 1 ? \"Duress Fingerprint\" : \"Normal Fingerprint\";\n            list.push({ id: res.finger_id, type });\n        }\n    } else if (res.action === \"delete\") {\n        list = list.filter(fp => fp.id !== res.finger_id);\n    }\n}\n\nflow.set(\"fingerprints\", list);\nmsg.payload = { fingerprints: list };\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 160,
        "wires": [
            [
                "ui_table"
            ]
        ]
    },
