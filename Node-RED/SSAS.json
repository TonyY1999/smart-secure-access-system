    {
        "id": "2734cdd1b907fce4",
        "type": "function",
        "z": "mqtt_full_ui_tab",
        "name": "Parse Request",
        "func": "// Topic: device/fingerprint/request\nlet req = msg.payload;\n\nif (req.request === \"add\" || req.request === \"delete\") {\n    msg.payload = {\n        show: true,\n        action: req.request,\n        finger_id: req.finger_id,\n        message: `Do you allow ${req.request === \"add\" ? \"add\" : \"delete\"} Fingerprint ID ${req.finger_id}？`\n    };\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 140,
        "y": 160,
        "wires": [
            [
                "ui_buttons"
            ]
        ]
    },
    {
        "id": "f9a85bb2c71381a0",
        "type": "mqtt in",
        "z": "mqtt_full_ui_tab",
        "name": "",
        "topic": "a10g/library/fingerprint",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "0f3329b0ff892f06",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 120,
        "y": 80,
        "wires": [
